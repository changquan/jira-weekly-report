# --- JIRA Cloud connection (required) ---
# Base URL of your Atlassian Cloud site, no trailing path.
JIRA_BASE_URL=https://your-site.atlassian.net
# The email address of the account that owns the API token.
JIRA_EMAIL=you@example.com
# Create one at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_api_token_here
# The JIRA project the report is scoped to.
JIRA_PROJECT_KEY=ABC

# --- Report tuning (optional; sensible defaults shown) ---
# Name of the JIRA issue type treated as an "initiative" for risk + milestones.
INITIATIVE_ISSUE_TYPE=Initiative
# An initiative is "at risk" if it is not Done and is overdue or due within this many days.
RISK_WINDOW_DAYS=14
# HTTP timeout (seconds) and page size for JIRA search requests.
REQUEST_TIMEOUT_SECONDS=30
MAX_RESULTS_PER_PAGE=100

# --- Development ---
# Serve generated mock JIRA data (issues, subtasks, comment threads) instead of
# calling JIRA. Useful for trying the report and AI summaries without a JIRA
# instance — the JIRA_* values above still need to be set but can be dummies.
# MOCK_JIRA=true

# --- AI progress summaries (optional) ---
# When set, each resolved issue in the "Progress" column gets an AI summary of
# the comments left on it (and on its subtasks) during the reporting window —
# what was actually done. Leave unset to disable.
# Create a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OpenAI model used for summaries.
# OPENAI_MODEL=gpt-5-mini
# Max concurrent comment-fetch + summary pipelines.
# SUMMARY_MAX_CONCURRENCY=4

# --- Advanced: override the generated JQL entirely (optional) ---
# If set, these are used verbatim instead of the built-in queries.
# The default THIS_WEEK_JQL is "sprint in openSprints()", which matches every
# active sprint in the JIRA instance. If other teams run sprints on the same
# instance, override it to scope to your board's sprint or projects, e.g.:
# THIS_WEEK_JQL=sprint in openSprints() AND project in (ABC, OPS)
# PROGRESS_JQL=
# RISK_JQL=
# MILESTONES_JQL=
